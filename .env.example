# EUEE Abebe Bot — Environment Template
# Fill these in on Railway or in your local .env file.
# DO NOT COMMIT THE ACTUAL .ENV FILE.

# Telegram
BOT_TOKEN=your_telegram_bot_token
WEBHOOK_URL=https://your-app.up.railway.app
WEBHOOK_SECRET=generate_a_random_string_here

# Administration
ADMIN_USER_ID=YOUR_TELEGRAM_ID
ADMIN_USER_ID_2=0
ADMIN_TOKEN=generate_a_strong_random_token
BASE_WEB_URL=https://your-app.up.railway.app
PUBLIC_BOT_USERNAME=EUEEMaster_Bot
TELEBIRR_NUMBER=0912345678

# Database (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://postgres.your-id:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# AI Providers (At least one required)
GEMINI_API_KEY=your_gemini_key
GROQ_API_KEY=your_groq_key
ANTHROPIC_API_KEY=your_anthropic_key
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=

# Optional
ALLOW_DEMO_UPGRADE=false
DEV_MODE=false
REDIS_URL=
PREFER_ELEVENLABS_FOR_AUDIO=false
ELEVENLABS_API_KEY=
